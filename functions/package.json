{
  "name": "gut-health-functions",
  "description": "Cloud Functions for AI Gut Health & IBS Tracker",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "seed": "ts-node src/seedFodmapDatabase.ts"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google/genai": "^1.37.0",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.3.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.4.0",
    "typescript": "^5.7.0",
    "ts-node": "^10.9.0"
  },
  "private": true
}
