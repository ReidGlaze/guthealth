rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // FODMAP database is read-only for all authenticated users
    match /fodmapDatabase/{foodId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Rate limit tracking (written by Cloud Functions only)
    match /rateLimits/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId} {
      // User profile
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdAt']));
      allow delete: if isOwner(userId);

      // Meals
      match /meals/{mealId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['createdAt', 'mealType', 'foods'])
          && request.resource.data.mealType in ['breakfast', 'lunch', 'dinner', 'snack']
          && request.resource.data.foods is list
          && request.resource.data.foods.size() <= 50;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Symptoms
      match /symptoms/{symptomId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['createdAt', 'type', 'severity'])
          && request.resource.data.type in ['bloating', 'gas', 'pain', 'heartburn', 'nausea', 'diarrhea', 'constipation', 'cramping']
          && request.resource.data.severity is number
          && request.resource.data.severity >= 1
          && request.resource.data.severity <= 10;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Poop Logs
      match /poopLogs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['createdAt', 'bristolType'])
          && request.resource.data.bristolType is int
          && request.resource.data.bristolType >= 1
          && request.resource.data.bristolType <= 7;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Daily Summaries (written by Cloud Functions via Admin SDK, readable by owner)
      match /dailySummaries/{dateKey} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // Correlations (written by Cloud Functions via Admin SDK, readable by owner)
      match /correlations/{corrId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // Weekly Insights (written by Cloud Functions via Admin SDK, readable by owner)
      match /weeklyInsights/{weekKey} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }
  }
}
